<div class="space-y-6 animate-fade-up">
  <div class="text-center space-y-3">
    <h2 class="text-xl font-bold text-white">Round <%= state[:round] %> Complete</h2>
    <%
      flip7_player = state[:players].find { |p| !p[:has_busted] && GameLogic.flip7?(p) }
    %>
    <% if flip7_player %>
      <div class="inline-flex items-center gap-2 bg-amber-500/20 text-amber-300 px-5 py-2 rounded-full text-sm font-semibold animate-glow-gold">
        🎉 <%= flip7_player[:name] %> achieved Flip 7! (+15 bonus)
      </div>
    <% end %>
  </div>

  <!-- Round Scores -->
  <div class="bg-gray-900/40 rounded-xl border border-gray-800/50 divide-y divide-gray-800/50 overflow-hidden">
    <% state[:players].sort_by { |p| -(state[:round_scores]&.dig(p[:id].to_sym) || state[:round_scores]&.dig(p[:id]) || 0) }.each_with_index do |player, rank| %>
      <% round_score = state[:round_scores]&.dig(player[:id].to_sym) || state[:round_scores]&.dig(player[:id]) || 0 %>
      <div class="flex items-center justify-between px-5 py-3.5 animate-fade-up fade-delay-<%= [rank + 1, 4].min %>">
        <div class="flex items-center gap-3">
          <span class="font-medium text-white text-sm"><%= player[:name] %></span>
          <% if player[:has_busted] %>
            <span class="text-[10px] bg-red-500/15 text-red-400 px-2 py-0.5 rounded-full font-medium">Bust</span>
          <% end %>
          <% if player[:frozen_by] %>
            <span class="text-[10px] bg-cyan-500/15 text-cyan-400 px-2 py-0.5 rounded-full font-medium">Frozen</span>
          <% end %>
        </div>
        <div class="flex items-center gap-4 text-sm">
          <span class="font-bold <%= round_score > 0 ? 'text-emerald-400' : 'text-gray-600' %>">
            +<%= round_score %>
          </span>
          <span class="text-gray-500 text-xs">Total: <span class="text-white font-bold text-sm"><%= player[:score] %></span></span>
        </div>
      </div>
    <% end %>
  </div>

  <!-- Player Cards -->
  <% state[:players].each_with_index do |player, idx| %>
    <% if player[:cards].any? %>
      <div class="space-y-1.5">
        <div class="text-xs text-gray-500 font-medium"><%= player[:name] %>'s cards</div>
        <div class="flex flex-wrap gap-2">
          <% player[:cards].each_with_index do |card, card_idx| %>
            <%= render "games/card", card: card, player: player, card_index: card_idx %>
          <% end %>
        </div>
      </div>
    <% end %>
  <% end %>

  <!-- Next Round -->
  <div class="text-center pt-2">
    <%= button_to "Next Round →", next_round_game_path(game), method: :post, class: "bg-indigo-600 hover:bg-indigo-500 active:scale-95 text-white px-10 py-3 rounded-xl font-semibold transition-all cursor-pointer btn-press" %>
  </div>
</div>
