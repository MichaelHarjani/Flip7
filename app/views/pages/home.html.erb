<div class="min-h-full flex flex-col items-center justify-center px-4">
  <div class="w-full max-w-sm space-y-10">
    <!-- Logo -->
    <div class="text-center space-y-3 animate-fade-up">
      <h1 class="text-7xl font-black tracking-tighter text-white">Flip 7</h1>
      <p class="text-gray-500 text-sm tracking-wide">Press your luck. Collect cards. Don't bust.</p>
    </div>

    <!-- Play Options -->
    <div class="space-y-3 animate-fade-up" style="animation-delay: 0.1s">
      <%= link_to new_game_path(mode: "single_player"), class: "block w-full bg-indigo-600 hover:bg-indigo-500 active:scale-95 text-white text-center py-3.5 px-6 rounded-xl font-semibold transition-all btn-press" do %>
        Play vs AI
      <% end %>

      <%= link_to new_game_path(mode: "local_multiplayer"), class: "block w-full bg-gray-800/80 hover:bg-gray-700/80 active:scale-95 text-white text-center py-3.5 px-6 rounded-xl font-semibold transition-all border border-gray-700/50 btn-press" do %>
        Local Multiplayer
      <% end %>

      <div class="flex gap-3">
        <%= link_to new_room_path, class: "flex-1 bg-gray-800/80 hover:bg-gray-700/80 active:scale-95 text-white text-center py-3 px-4 rounded-xl font-medium transition-all border border-gray-700/50 btn-press" do %>
          Create Room
        <% end %>

        <%= link_to join_rooms_path, class: "flex-1 bg-gray-800/80 hover:bg-gray-700/80 active:scale-95 text-white text-center py-3 px-4 rounded-xl font-medium transition-all border border-gray-700/50 btn-press" do %>
          Join Room
        <% end %>
      </div>
    </div>

    <!-- How to Play -->
    <details class="group animate-fade-up" style="animation-delay: 0.2s">
      <summary class="text-gray-500 text-xs text-center cursor-pointer hover:text-gray-400 transition-colors list-none uppercase tracking-widest font-medium">
        How to Play
      </summary>
      <div class="mt-4 bg-gray-900/30 rounded-xl p-5 border border-gray-800/50 text-sm text-gray-400 space-y-3">
        <p><strong class="text-gray-200">Goal:</strong> First to reach 200 points wins.</p>
        <p><strong class="text-gray-200">Each round:</strong> Dealt one card. Choose to <span class="text-indigo-400 font-medium">Hit</span> (draw) or <span class="text-emerald-400 font-medium">Stay</span> (bank).</p>
        <p><strong class="text-gray-200">Bust:</strong> Draw a duplicate number = bust. Score 0 for the round.</p>
        <p><strong class="text-gray-200">Flip 7:</strong> 7 unique number cards = +15 bonus!</p>
        <div class="pt-3 border-t border-gray-800/50 space-y-1.5 text-xs text-gray-500">
          <p><span class="inline-block w-3 h-3 rounded bg-blue-500/60 align-middle mr-1.5"></span>Number cards (0–12)</p>
          <p><span class="inline-block w-3 h-3 rounded bg-emerald-500/60 align-middle mr-1.5"></span>Modifiers (+2 to +10)</p>
          <p><span class="inline-block w-3 h-3 rounded bg-purple-500/60 align-middle mr-1.5"></span>×2 Multiplier</p>
          <p><span class="inline-block w-3 h-3 rounded bg-amber-500/60 align-middle mr-1.5"></span>Action cards</p>
        </div>
      </div>
    </details>
  </div>

  <footer class="absolute bottom-6 text-gray-700 text-[10px] tracking-wider uppercase">
    Flip 7
  </footer>
</div>
